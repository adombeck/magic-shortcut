#!/bin/sh
# Handle file paths in clipboard (with optional line numbers)

PROJECTS_DIR="$HOME/projects"

if [ ! -d "$PROJECTS_DIR" ]; then
    echo >&2 "Warning: Projects directory '$PROJECTS_DIR' does not exist."
fi

find_in_projects() {
    # Check if the given relative path exists in the projects directory
    relative_path="$1"

    for project in "$PROJECTS_DIR"/*; do
        if [ -d "$project" ]; then
            potential_path="$project/$relative_path"
            if [ -f "$potential_path" ]; then
                echo "$potential_path"
                return
            fi
        fi
    done

    return
}

find_file() {
    # Check if the given path exists as an absolute path
    if [ -f "$1" ]; then
        echo "$1"
        return
    fi

    # If the path is absolute, there's no need to check in projects
    if [ "${1#/}" != "$1" ]; then
        return
    fi

    # Try to find it in the projects directory
    find_in_projects "$1"
}

is_valid_number() {
    echo "$1" | grep -qE '^[0-9]+$'
}

parse_colon_format() {
    # Parse "path/to/file:line_number" format
    text="$1"
    potential_path="${text%%:*}"
    rest="${text#*:}"
    rest="${rest%%:*}"  # Remove trailing colon if present

    if [ "$potential_path" = "$text" ]; then
        # Not in "path:line" format
        return 1
    fi

    found_path=$(find_file "$potential_path")
    if [ -z "$found_path" ]; then
        return 1
    fi

    if [ -n "$rest" ] && is_valid_number "$rest"; then
        echo "$found_path"
        echo "$rest"
        return 0
    fi

    return 1
}

parse_github_format() {
    # Parse "path/to/file#Lline_number" format
    text="$1"
    potential_path="${text%%#L*}"
    rest="${text#*#L}"

    if [ "$potential_path" = "$text" ]; then
        # Not in "path#Lline" format
        return 1
    fi

    found_path=$(find_file "$potential_path")
    if [ -z "$found_path" ]; then
        return 1
    fi

    if [ -n "$rest" ] && is_valid_number "$rest"; then
        echo "$found_path"
        echo "$rest"
        return 0
    fi

    return 1
}

extract_path_and_line() {
    text="$1"

    found_path=$(find_file "$text")
    if [ -n "$found_path" ]; then
        echo "$found_path"
        return 0
    fi

    # Try colon format
    if echo "$text" | grep -q ':'; then
        if parse_colon_format "$text"; then
            return
        fi
    fi

    # Try GitHub format
    if echo "$text" | grep -q '#L'; then
        if parse_github_format "$text"; then
            return
        fi
    fi

    return 1
}

output_json() {
    path="$1"
    line_number="$2"

    if [ -n "$line_number" ]; then
        body="$path:$line_number"
        jq -n \
            --arg path "$path" \
            --arg body "$body" \
            --argjson line "$line_number" \
            '{
                handled: true,
                message: {
                    title: "Opening File",
                    body: $body
                },
                action: "open_file",
                path: $path,
                line_number: $line
            }'
        return
    fi

    body="$path"
    jq -n \
        --arg path "$path" \
        --arg body "$body" \
        '{
            handled: true,
            message: {
                title: "Opening File",
                body: $body
            },
            action: "open_file",
            path: $path
        }'
}

clipboard=$(cat)

if ! result=$(extract_path_and_line "$clipboard"); then
    # Not a file path, we can't handle this
    exit 0
fi

path=$(echo "$result" | sed -n '1p')
line_number=$(echo "$result" | sed -n '2p')

output_json "$path" "$line_number"
